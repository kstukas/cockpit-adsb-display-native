<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CockpitDisplay.Views"
        x:Class="CockpitDisplay.Views.MainWindow"
        Title="CockpitDisplay"
        Width="480" Height="480"
        MinWidth="480" MinHeight="480"
        MaxWidth="480" MaxHeight="480"
        SystemDecorations="None"
        Background="Black"
        CanResize="False">
    <views:CockpitView />
</Window>
